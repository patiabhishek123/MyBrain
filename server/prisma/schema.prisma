generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceType {
  FILE
  URL
  TEXT
  MARKDOWN
  PDF
  DOCX
}

enum ResourceStatus {
  PROCESSING
  READY
  FAILED
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  projects     Project[]
  chatSessions ChatSession[]
  refreshTokens RefreshToken[]

  @@index([deletedAt])
}

model RefreshToken {
  id                String   @id @default(cuid())
  userId            String
  jti               String   @unique
  tokenHash         String
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  createdByIp       String?
  userAgent         String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([userId, revokedAt])
}

model Project {
  id        String   @id @default(cuid())
  ownerId   String
  name      String
  slug      String
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  owner         User            @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  sources       Source[]
  chunks        DocumentChunk[]
  chatSessions  ChatSession[]
  messages      Message[]

  @@unique([ownerId, slug])
  @@index([ownerId])
  @@index([deletedAt])
}

model Source {
  id           String         @id @default(cuid())
  projectId    String
  type         SourceType
  status       ResourceStatus @default(PROCESSING)
  title        String?
  externalRef  String?
  checksum     String?
  errorMessage String?
  metadata     Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chunks  DocumentChunk[]

  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
  @@index([projectId, type])
  @@index([projectId, createdAt])
}

model DocumentChunk {
  id                 String         @id @default(cuid())
  projectId          String
  sourceId           String
  chunkIndex         Int
  content            String         @db.Text
  tokenCount         Int?
  status             ResourceStatus @default(PROCESSING)
  pineconeNamespace  String?
  pineconeId         String?
  embeddingModel     String?
  embeddingDimension Int?
  metadata           Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  deletedAt          DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  source  Source  @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, chunkIndex])
  @@index([projectId])
  @@index([sourceId])
  @@index([status])
  @@index([deletedAt])
  @@index([projectId, sourceId])
  @@index([projectId, createdAt])
}

model ChatSession {
  id            String         @id @default(cuid())
  projectId     String
  userId        String
  title         String?
  status        ResourceStatus @default(READY)
  metadata      Json?
  lastMessageAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  messages Message[]

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@index([deletedAt])
  @@index([projectId, userId, createdAt])
}

model Message {
  id            String      @id @default(cuid())
  projectId     String
  chatSessionId String
  role          MessageRole
  content       String      @db.Text
  model         String?
  tokenCount    Int?
  latencyMs     Int?
  metadata      Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([chatSessionId])
  @@index([role])
  @@index([deletedAt])
  @@index([projectId, chatSessionId, createdAt])
}
